VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# URL base da API (verify + admin). Produção: URL do Render (ex: https://ola-jamal.onrender.com)
VITE_API_URL=https://renovejasaude.com.br

# Formspree: formulário de contato envia direto para seu email (sem abrir cliente de email).
# Crie em https://formspree.io e defina o email de destino (ex: contato@renovejasaude.com.br)
VITE_FORMSPREE_FORM_ID=
