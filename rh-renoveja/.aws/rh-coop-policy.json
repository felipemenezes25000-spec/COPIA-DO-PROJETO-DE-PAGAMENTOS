{
  "Name": "renoveja-rh-coop-oauth",
  "Comment": "COOP/COEP headers necessarios para popup do Google Identity Services (OAuth) no rh.renovejasaude.com.br",
  "CustomHeadersConfig": {
    "Quantity": 2,
    "Items": [
      {
        "Header": "Cross-Origin-Opener-Policy",
        "Value": "same-origin-allow-popups",
        "Override": true
      },
      {
        "Header": "Cross-Origin-Embedder-Policy",
        "Value": "unsafe-none",
        "Override": true
      }
    ]
  }
}
