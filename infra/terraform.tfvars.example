# ============================================================
# terraform.tfvars.example
# Copie para terraform.tfvars e preencha com valores reais.
# NUNCA commite terraform.tfvars no Git (já está no .gitignore).
# ============================================================

# Região AWS (padrão: sa-east-1 = São Paulo)
aws_region = "sa-east-1"

# Ambiente (prod | staging)
environment = "prod"

# Senha do banco PostgreSQL (mínimo 16 chars, sem @ ou espaços)
db_password = "TROQUE_PARA_SENHA_FORTE_AQUI"

# Capacidade ECS (aumente conforme demanda)
ecs_cpu           = 512   # 0.5 vCPU
ecs_memory        = 1024  # 1 GB
ecs_desired_count = 2     # mínimo de tasks rodando

# Capacidade Aurora Serverless v2 (ACUs)
aurora_min_acu = 0.5
aurora_max_acu = 4
