<Project>
  <PropertyGroup>
    <!-- Evita que avisos de vulnerabilidade de pacotes (NU1901/2/3) falhem o build em CI -->
    <NoWarn>$(NoWarn);NU1901;NU1902;NU1903</NoWarn>
    <!-- Build determinístico: não tratar avisos como erros por padrão -->
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>
</Project>
