{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend-dotnet",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "dotnet run --project backend-dotnet/src/RenoveJa.Api"],
      "port": 5000
    },
    {
      "name": "frontend-web",
      "runtimeExecutable": "node",
      "runtimeArgs": ["frontend-web/node_modules/vite/bin/vite.js", "--config", "frontend-web/vite.config.ts", "--host"],
      "port": 5173
    },
    {
      "name": "frontend-mobile",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "cd frontend-mobile && npm run start"],
      "port": 8081
    }
  ]
}
